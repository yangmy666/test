      },
      {
        "author": "",
        "text": "How do we prepare to capitalize on earnings this week? Any practical tips?",
        "time_str": "17 小时前",
        "likes": 2,
        "level": 1
      },
      {
        "author": "",
        "text": "Kristen is great! Guides us to the light!",
